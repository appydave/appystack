{
  "name": "@appystack-template/server",
  "version": "0.1.0",
  "private": true,
  "description": "Express + Socket.io server for AppyStack template",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@appydave/core": "^0.1.0",
    "@appystack-template/shared": "*",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.0.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.13.3",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "nodemon": "^3.1.14",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.0.0",
    "tsc-alias": "^1.9.0",
    "tsx": "^4.23.0",
    "vitest": "^4.1.10"
  }
}
